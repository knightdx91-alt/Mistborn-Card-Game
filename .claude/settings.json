{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "mcp__github__create_branch",
      "mcp__github__create_pull_request",
      "mcp__github__fork_repository"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-main-only.sh\"",
            "statusMessage": "Checking main-only workflow policy"
          }
        ]
      }
    ]
  }
}
